# Copper - NVE + Langevin ( it adds random forces and friction to each atom independently, like atoms moving through a viscous fluid at 300 K)
units           metal
atom_style      atomic
boundary        p p p

lattice         fcc 3.615
region          box block 0 5 0 5 0 5
create_box      1 box
create_atoms    1 box
mass            1 63.546

pair_style      eam
pair_coeff      1 1 Cu_u3.eam

velocity        all create 300 12345 dist gaussian mom yes rot yes
fix             1 all nve
fix             2 all langevin 300 300 0.1 12345
timestep        0.001

thermo          100
thermo_style    custom step temp pe ke etotal press
run             10000
